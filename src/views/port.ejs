<div class="tab-panel hidden" id="tab-ports">
  <div class="ports-panel">
    <div class="ports-toolbar">
      <div class="ports-toolbar-left">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" style="color:var(--cyan)"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>
        <span class="ports-title">Open Ports</span>
        <span class="ports-count" id="ports-count">0</span>
      </div>
      <button class="tool-btn" id="ports-refresh-btn">Refresh</button>
    </div>
    <div class="ports-list" id="ports-list">
      <div class="loading-ports">Scanning…</div>
    </div>
    <div class="port-preview-panel hidden" id="port-preview-panel">
      <div class="port-preview-bar">
        <div class="port-preview-bar-left">
          <span class="port-preview-badge" id="port-preview-badge">:8080</span>
          <span id="port-preview-url" class="port-preview-url">localhost</span>
        </div>
        <div class="port-preview-bar-right">
          <button class="port-preview-btn port-preview-close" id="port-preview-close">&times;</button>
        </div>
      </div>
      <iframe id="port-preview-iframe" class="port-preview-iframe" src="about:blank"></iframe>
    </div>
  </div>
</div>
