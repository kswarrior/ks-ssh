<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>KS SSH | HUD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/xterm.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💠</text></svg>" />
</head>
<body>
<div id="app">

  <header class="hud-header">
    <div class="header-left">
        <div class="header-brand">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            <span>KS SSH</span>
        </div>

        <nav class="top-nav">
          <div class="nav-link active" data-tab="terminals">Terminal</div>
          <div class="nav-link" data-tab="files">Files</div>
          <div class="nav-link" data-tab="ports">Ports</div>
        </nav>

        <div class="header-stats">
            <div class="header-stat-item">
                <span id="hdr-ram-pct" class="header-stat-value">0%</span> RAM
            </div>
            <div class="header-stat-item">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="var(--electric-blue)" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>
                <span id="hdr-latency" class="header-stat-value">--ms</span>
            </div>
        </div>
    </div>

    <div class="header-right">
        <button class="icon-btn" id="settings-btn" title="HUD Settings"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
        <div class="dropdown-wrapper">
            <button class="icon-btn" id="vps-info-btn" title="VPS Information"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12h-4l-3 9L9 3l-3 9H2"/></svg></button>
            <div class="dropdown-menu hidden" id="vps-info-dropdown">
                <div class="dropdown-header">System Information</div>
                <div class="dropdown-content neofetch-layout">
                    <pre id="vps-logo" class="neofetch-logo">🐧</pre>
                    <div class="neofetch-details">
                        <div class="nf-user-host"><span id="nf-user">user</span>@<span id="nf-host">host</span></div>
                        <div class="nf-separator">-----------------</div>
                        <div class="nf-row"><span class="nf-key">OS:</span> <span id="nf-os">--</span></div>
                        <div class="nf-row"><span class="nf-key">Host:</span> <span id="nf-platform">--</span></div>
                        <div class="nf-row"><span class="nf-key">Kernel:</span> <span id="nf-kernel">--</span></div>
                        <div class="nf-row"><span class="nf-key">Uptime:</span> <span id="nf-uptime">--</span></div>
                        <div class="nf-row"><span class="nf-key">Packages:</span> <span id="nf-packages">--</span></div>
                        <div class="nf-row"><span class="nf-key">Shell:</span> <span id="nf-shell">--</span></div>
                        <div class="nf-row"><span class="nf-key">CPU:</span> <span id="nf-cpu">--</span></div>
                        <div class="nf-row"><span class="nf-key">Memory:</span> <span id="nf-mem">--</span></div>
                        <div class="nf-row"><span class="nf-key">IP:</span> <span id="nf-ip" class="text-blue">--</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </header>


  <main class="hud-main">
    <%- include('terminal') %>
    <%- include('port') %>
    <%- include('file') %>
  </main>

  <footer class="hud-footer">
    <div id="footer-status">READY FOR OPERATION</div>
    <div class="footer-right">
        <span class="copyright-notice">©️ KS Warrior</span>
        <span class="text-blue">KS-SSH HUD v2.0</span>
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/></svg>
    </div>
  </footer>

  <!-- Mobile HUD Dock -->
  <div class="mobile-dock">
      <div class="dock-item active" data-tab="terminals">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          <span>TERM</span>
      </div>
      <div class="dock-item" data-tab="files">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 2h9a2 2 0 0 1 2 2v12z"/></svg>
          <span>FILES</span>
      </div>
      <div class="dock-item" data-tab="ports">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span>NET</span>
      </div>
  </div>

</div>

<%- include('partials/modals') %>
<div class="toast-container" id="toast-container"></div>
<%- include('partials/scripts') %>
</body>
</html>
