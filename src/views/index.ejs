<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>KS SSH | HUD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/xterm.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💠</text></svg>" />
</head>
<body>
<div id="app">

    <header class="hud-header" style="background: #000; border-bottom: 2px solid var(--night-700);">
    <div class="header-left">
        <div class="header-brand" style="color: #fff; font-weight: 900;">
            <div style="background: var(--electric-blue); color: #fff; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 4px; margin-right: 8px;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </div>
            <span>KS SSH</span>
        </div>

        <nav class="top-nav">
          <button id="sidebar-toggle-btn" class="icon-btn" title="Toggle Explorer" style="margin-right: 8px; color: var(--text-blue);"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg></button>
          <div class="nav-link active" data-tab="terminals">Terminal</div>
          <div class="nav-link" data-tab="files">Files</div>
          <div class="nav-link" data-tab="ports">Ports</div>
          <div class="nav-link" data-tab="processes">Tasks</div>
        </nav>

        <div class="header-stats">
            <div class="header-stat-item">
                <span id="hdr-ram-pct">0%</span> RAM
            </div>
            <div class="header-stat-item">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#22c55e" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>
                <span id="hdr-latency">--ms</span>
            </div>
        </div>
    </div>

    <div class="header-right">
        <div class="dropdown-wrapper">
            <button class="icon-btn" id="theme-btn" title="Appearance" style="margin-right: 4px;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg></button>
            <div class="dropdown-menu hidden" id="theme-dropdown" style="width: 180px;">
                <div class="dropdown-header">Theme HUD</div>
                <div style="padding: 8px;">
                    <div class="theme-opt" data-theme="default" style="padding:8px 12px; cursor:pointer; border-radius:4px; font-size:12px; font-weight:600; color:var(--text-blue);">Electric Blue</div>
                    <div class="theme-opt" data-theme="emerald" style="padding:8px 12px; cursor:pointer; border-radius:4px; font-size:12px; font-weight:600; color:#10b981;">Emerald Cyber</div>
                    <div class="theme-opt" data-theme="ruby" style="padding:8px 12px; cursor:pointer; border-radius:4px; font-size:12px; font-weight:600; color:#ef4444;">Ruby Crimson</div>
                    <div class="theme-opt" data-theme="gold" style="padding:8px 12px; cursor:pointer; border-radius:4px; font-size:12px; font-weight:600; color:#f59e0b;">Liquid Gold</div>
                </div>
            </div>

            <button class="icon-btn" id="vps-info-btn" title="VPS Information"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12h-4l-3 9L9 3l-3 9H2"/></svg></button>
            <div class="dropdown-menu hidden" id="vps-info-dropdown">
                <div class="dropdown-header">KS SSH — System Information</div>
                <div class="dropdown-content neofetch-layout">
                    <pre id="vps-logo" class="neofetch-logo">🐧</pre>
                    <div class="neofetch-details">
                        <div class="nf-user-host"><span id="nf-user">user</span>@<span id="nf-host">host</span></div>
                        <div class="nf-separator">-----------------</div>
                        <div class="nf-row"><span class="nf-key">OS:</span> <span id="nf-os">--</span></div>
                        <div class="nf-row"><span class="nf-key">Host:</span> <span id="nf-platform">--</span></div>
                        <div class="nf-row"><span class="nf-key">Kernel:</span> <span id="nf-kernel">--</span></div>
                        <div class="nf-row"><span class="nf-key">Uptime:</span> <span id="nf-uptime">--</span></div>
                        <div class="nf-row"><span class="nf-key">Packages:</span> <span id="nf-packages">--</span></div>
                        <div class="nf-row"><span class="nf-key">Shell:</span> <span id="nf-shell">--</span></div>
                        <div class="nf-row"><span class="nf-key">CPU:</span> <span id="nf-cpu" style="color:var(--text-pure);">--</span></div>
                        <div id="nf-cpu-cores-list" style="margin-top:4px;"></div>

                        <div class="nf-row" style="margin-top:8px;"><span class="nf-key">Memory:</span> <span id="nf-mem">--</span></div>
                        <div class="nf-bar-container"><div id="nf-mem-bar" class="nf-bar-fill" style="width: 0%;"></div></div>

                        <div class="nf-row"><span class="nf-key">Disk:</span> <span id="nf-disk">--</span></div>
                        <div class="nf-bar-container"><div id="nf-disk-bar" class="nf-bar-fill" style="width: 0%; background:#a855f7; box-shadow:0 0 6px rgba(168,85,247,0.4);"></div></div>

                        <div class="nf-row"><span class="nf-key">IP:</span> <span id="nf-ip" class="text-blue" style="font-weight: 800;">--</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </header>


  <main class="hud-main">
    <aside id="hud-sidebar" class="hud-sidebar hidden">
        <%- include('file') %>
    </aside>

    <section class="hud-workspace">
        <%- include('terminal') %>
        <%- include('port') %>

        <div class="tab-panel hidden" id="tab-processes">
        <div style="padding:20px; display:flex; flex-direction:column; height:100%;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding:0 16px;">
                <div>
                    <h1 style="font-weight:900; letter-spacing:-0.04em; font-size:24px;">Process HUD</h1>
                    <p style="font-size:12px; color:var(--text-dim); margin-top:4px;">TOP RESOURCES BY CPU</p>
                </div>
                <button id="proc-refresh-btn" class="btn-primary" style="padding:8px 16px; font-size:12px; box-shadow:none;">REFRESH</button>
            </div>
            <div id="proc-list" class="flex-1 scroll-y" style="padding:0 16px;"></div>
        </div>
    </section>

    <!-- Port Preview Panel -->
    <div id="port-preview-panel" class="port-preview-panel hidden">
        <div class="preview-header">
            <div style="display:flex; align-items:center; gap:12px;">
                <div class="preview-dot"></div>
                <div class="preview-title">Live Preview <span id="port-preview-badge">:0</span></div>
            </div>
            <div style="display:flex; gap:10px;">
                <button id="port-preview-refresh" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
                <button id="port-preview-pop" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></button>
                <button id="port-preview-close" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
            </div>
        </div>
        <div class="preview-address-bar">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--text-dim);"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span id="port-preview-url">localhost:0</span>
        </div>
        <div class="preview-body">
            <iframe id="port-preview-iframe" src="about:blank"></iframe>
        </div>
    </div>
  </main>

  <footer class="hud-footer">
    <div id="footer-status">No buttons yet — press + to add one</div>
    <div style="display:flex; gap:12px;">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </div>
  </footer>

</div>

<%- include('partials/modals') %>

<!-- Command Palette -->
<div id="cmd-palette" class="modal-overlay hidden">
    <div class="modal" style="margin-top: 10vh; max-width: 600px;">
        <div style="padding: 8px;">
            <input type="text" id="cmd-input" class="input-hud" placeholder="Type a command or search..." autocomplete="off" />
        </div>
        <div id="cmd-results" class="scroll-y" style="max-height: 300px; padding: 4px;"></div>
    </div>
</div>

<div class="toast-container" id="toast-container"></div>
<%- include('partials/scripts') %>
</body>
</html>
