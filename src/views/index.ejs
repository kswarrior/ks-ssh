<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>KS SSH | HUD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/xterm.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💠</text></svg>" />
</head>
<body>
<div id="app">

  <header class="hud-header">
    <div class="header-left">
        <div class="header-brand">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="3"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            <span>KS SSH</span>
        </div>

        <nav class="top-nav">
          <div class="nav-link active" data-tab="terminals">Terminal</div>
          <div class="nav-link" data-tab="files">Files</div>
          <div class="nav-link" data-tab="ports">Ports</div>
        </nav>

        <div class="header-stats">
            <div class="header-stat-item">
                <span id="hdr-ram-pct">0%</span> RAM
            </div>
            <div class="header-stat-item">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#22c55e" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>
                <span id="hdr-latency">--ms</span>
            </div>
        </div>
    </div>

    <div class="header-right">
        <div class="dropdown-wrapper">
            <button class="icon-btn" id="vps-info-btn" title="VPS Information"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12h-4l-3 9L9 3l-3 9H2"/></svg></button>
            <div class="dropdown-menu hidden" id="vps-info-dropdown">
                <div class="dropdown-header">System Information (Neofetch)</div>
                <div class="dropdown-content neofetch-layout">
                    <pre id="vps-logo" class="neofetch-logo">🐧</pre>
                    <div class="neofetch-details">
                        <div class="nf-user-host"><span id="nf-user">user</span>@<span id="nf-host">host</span></div>
                        <div class="nf-separator">-----------------</div>
                        <div class="nf-row"><span class="nf-key">OS:</span> <span id="nf-os">--</span></div>
                        <div class="nf-row"><span class="nf-key">Host:</span> <span id="nf-platform">--</span></div>
                        <div class="nf-row"><span class="nf-key">Kernel:</span> <span id="nf-kernel">--</span></div>
                        <div class="nf-row"><span class="nf-key">Uptime:</span> <span id="nf-uptime">--</span></div>
                        <div class="nf-row"><span class="nf-key">Packages:</span> <span id="nf-packages">--</span></div>
                        <div class="nf-row"><span class="nf-key">Shell:</span> <span id="nf-shell">--</span></div>
                        <div class="nf-row"><span class="nf-key">CPU:</span> <span id="nf-cpu">--</span></div>
                        <div class="nf-row"><span class="nf-key">Memory:</span> <span id="nf-mem">--</span></div>
                        <div class="nf-row"><span class="nf-key">IP:</span> <span id="nf-ip" class="text-blue">--</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </header>


  <main class="hud-main">
    <%- include('terminal') %>
    <%- include('port') %>
    <%- include('file') %>
  </main>

  <footer class="hud-footer">
    <div id="footer-status">No buttons yet — press + to add one</div>
    <div style="display:flex; gap:12px;">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </div>
  </footer>

</div>

<%- include('partials/modals') %>
<div class="toast-container" id="toast-container"></div>
<%- include('partials/scripts') %>
</body>
</html>
