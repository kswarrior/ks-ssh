<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>KS SSH | HUD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/xterm.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💠</text></svg>" />
</head>
<body>
<div id="app">

  <header class="hud-header">
    <div class="header-left">
        <div class="header-brand">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="3"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            KS SSH
        </div>

        <nav class="top-nav">
          <div class="nav-link active" data-tab="terminals">Terminal</div>
          <div class="nav-link" data-tab="files">Files</div>
          <div class="nav-link" data-tab="ports">Ports</div>
        </nav>

        <div class="header-stats">
            <div class="header-stat-item">
                <span id="hdr-ram-pct">0%</span> RAM
            </div>
            <div class="header-stat-item">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#22c55e" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>
                <span id="hdr-latency">--ms</span>
            </div>
        </div>
    </div>

    <div class="header-right">
        <button class="icon-btn" id="res-mon-btn" title="Resource Monitor"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12h-4l-3 9L9 3l-3 9H2"/></svg></button>

        <div class="dropdown-wrapper">
            <button class="icon-btn" id="vps-info-btn" title="VPS Info"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82 1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
            <div class="dropdown-menu hidden" id="vps-info-dropdown">
                <div class="dropdown-header">VPS System Information</div>
                <div class="dropdown-content">
                    <div class="info-grid">
                        <div class="info-label">CPU Model</div><div class="info-value" id="vps-cpu-model">--</div>
                        <div class="info-label">Cores</div><div class="info-value" id="vps-cpu-cores">--</div>
                        <div class="info-label">RAM</div><div class="info-value" id="vps-ram-usage">--</div>
                        <div class="info-label">Disk</div><div class="info-value" id="vps-disk-usage">--</div>
                        <div class="info-label">IP Address</div><div class="info-value text-blue" id="vps-ip">--</div>
                    </div>
                </div>
            </div>
        </div>

        <button class="icon-btn" id="ks-key-btn" title="Master Key"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></button>
    </div>
  </header>


  <main class="hud-main">
    <%- include('terminal') %>
    <%- include('port') %>
    <%- include('file') %>
  </main>

  <footer class="hud-footer">
    <div id="footer-status">No buttons yet — press + to add one</div>
    <div style="display:flex; gap:12px;">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </div>
  </footer>

</div>

<%- include('partials/modals') %>
<div class="toast-container" id="toast-container"></div>
<%- include('partials/scripts') %>
</body>
</html>
