<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>KS SSH | HUD MASTER</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/xterm.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💠</text></svg>" />
</head>
<body>
<div id="app">

  <header class="hud-panel hud-header">
    <div class="hud-logo">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="3"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
      <span>KS SSH <span>HUD</span></span>
    </div>

    <div class="hud-stats">
      <div class="hud-stat-item" id="tunnel-info-stat" style="display:none; border-color:var(--electric-cyan);">
        <span class="hud-stat-label" style="color:var(--electric-cyan)">TUNNEL ACTIVE</span>
        <span class="hud-stat-value" id="hud-tunnel-token" style="cursor:pointer;" title="Click to copy URL">---</span>
      </div>
      <div class="hud-stat-item">
        <span class="hud-stat-label">Uptime</span>
        <span class="hud-stat-value" id="hud-uptime">--:--:--</span>
      </div>
      <div class="hud-stat-item">
        <span class="hud-stat-label">Session</span>
        <span class="hud-stat-value" id="hud-session-count">0 ACTIVE</span>
      </div>
      <div class="hud-stat-item">
        <span class="hud-stat-label">Host</span>
        <span class="hud-stat-value" id="sys-host">DEVBOX</span>
      </div>
    </div>
  </header>

  <nav class="hud-panel hud-nav">
    <div class="hud-nav-item active" data-tab="terminals" title="Command HUD">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
    </div>
    <div class="hud-nav-item" data-tab="ports" title="Network HUD">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>
    </div>
    <div class="hud-nav-item" data-tab="files" title="Storage HUD">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 3h6l2 2h9a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/></svg>
    </div>
    <div style="margin-top:auto; padding-bottom:12px;">
        <button id="info-btn" style="background:none; border:none; color:var(--text-dim); cursor:pointer;"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></button>
    </div>
  </nav>

  <main class="hud-panel hud-main">
    <%- include('terminal') %>
    <%- include('port') %>
    <%- include('file') %>
  </main>

  <aside class="hud-panel hud-monitor">
    <div class="hud-section-title">System Metrics</div>

    <div class="hud-metric">
      <div class="hud-metric-header"><span>Processor</span><span id="rm-cpu-label">0%</span></div>
      <div class="hud-progress-track"><div id="rm-cpu-bar" class="hud-progress-fill" style="width:0%"></div></div>
    </div>

    <div class="hud-metric">
      <div class="hud-metric-header"><span>Memory</span><span id="rm-ram-label">0%</span></div>
      <div class="hud-progress-track"><div id="rm-ram-bar" class="hud-progress-fill" style="width:0%"></div></div>
    </div>

    <div class="hud-section-title" style="margin-top:20px;">Processor HUD</div>
    <div id="rm-cores-container" style="display:grid; grid-template-columns:repeat(4, 1fr); gap:12px;"></div>

    <div class="hud-section-title" style="margin-top:auto;">Network I/O</div>
    <div style="font-family:var(--font-mono); font-size:12px; display:flex; flex-direction:column; gap:8px;">
        <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--text-dim)">INBOUND</span>
            <span id="rm-net-in" style="color:var(--electric-cyan)">0 B/s</span>
        </div>
        <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--text-dim)">OUTBOUND</span>
            <span id="rm-net-out" style="color:var(--electric-cyan)">0 B/s</span>
        </div>
    </div>
  </aside>

</div>

<%- include('partials/modals') %>

<div class="toast-container" id="toast-container"></div>

<%- include('partials/scripts') %>
</body>
</html>
