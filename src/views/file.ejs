<div id="tab-files" class="tab-panel hidden" style="height:100%;">
  <div style="padding:16px; display:flex; flex-direction:column; height:100%;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding:0 16px;">
        <div style="flex: 1;">
            <h1 style="font-weight:900; letter-spacing:-0.04em; font-size:24px;">Storage HUD</h1>
            <div id="breadcrumb" style="font-family:var(--font-mono); font-size:11px; color:var(--text-blue); margin-top:4px; overflow-x: auto; white-space: nowrap; scrollbar-width: none;">/ROOT</div>
        </div>
        <div style="display:flex; gap:10px;">
            <button id="upload-btn" class="btn-primary" style="padding:8px 16px; font-size:12px; box-shadow:none;">UPLOAD</button>
            <button id="url-upload-btn" class="icon-btn" title="Upload from URL"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></button>
            <button id="select-btn" class="icon-btn" title="Toggle Multi-Select"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="9 11 12 14 22 4"/></svg></button>
            <button id="new-file-btn" class="icon-btn" title="New File"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg></button>
            <button id="new-folder-btn" class="icon-btn" title="New Folder"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 2h9a2 2 0 0 1 2 2v12z"/></svg></button>
            <button id="files-refresh-btn" class="icon-btn" title="Refresh"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
        </div>
    </div>

    <div style="padding: 0 16px 16px;">
        <input type="text" id="files-search" class="input-hud" placeholder="Search files in current directory..." style="font-size:12px; padding:8px 12px;" />
    </div>

    <div id="files-list" class="files-list-vertical flex-1"></div>

    <div id="bulk-bar" class="hidden" style="margin: 16px; padding: 12px 20px; background: var(--night-800); border: 1px solid var(--glass-border); border-radius: 8px; display: flex; align-items: center; justify-content: space-between;">
        <div id="bulk-count" style="font-weight:700; font-size:13px; color:var(--text-blue);">0 ITEMS SELECTED</div>
        <div style="display:flex; gap:10px;">
            <button id="bulk-zip" class="btn-primary" style="padding:6px 12px; font-size:11px; background:var(--night-700); box-shadow:none;">MAKE ZIP</button>
            <button id="bulk-delete" class="btn-primary" style="padding:6px 12px; font-size:11px; background:#ef4444; box-shadow:none;">DELETE</button>
            <button id="bulk-cancel" class="icon-btn" style="padding:4px;"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
    </div>
  </div>
</div>

<input type="file" id="file-input" multiple class="hidden" />

<!-- Context Menu -->
<div id="file-context-menu" class="context-menu hidden">
    <div class="menu-item" id="ctx-download"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Download</div>
    <div class="menu-item" id="ctx-edit"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</div>
    <div class="menu-item" id="ctx-rename"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg> Rename</div>
    <div class="menu-item" id="ctx-copy-path"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> Copy Path</div>
    <div style="height:1px; background:var(--glass-border); margin:4px 0;"></div>
    <div class="menu-item danger" id="ctx-delete"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</div>
</div>

<!-- URL Upload Modal -->
<div class="modal-overlay hidden" id="url-upload-modal">
    <div class="modal">
        <div class="modal-header"><h3>Upload from URL</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body">
            <div style="margin-bottom:12px;"><label style="font-size:12px; color:var(--text-dim);">RESOURCE URL</label></div>
            <input type="text" id="upload-url-input" class="input-hud" placeholder="https://example.com/file.zip" />
        </div>
        <div class="modal-footer">
            <button class="icon-btn modal-close" style="font-size:13px; font-weight:600;">CANCEL</button>
            <button id="url-upload-confirm" class="btn-primary" style="padding:8px 20px; font-size:13px;">UPLOAD</button>
        </div>
    </div>
</div>

<!-- Editor Modal -->
<div class="modal-overlay hidden" id="file-editor-modal">
    <div class="modal modal-editor">
        <div class="modal-header">
            <div style="display:flex; align-items:center; gap:12px;">
                <div id="editor-icon" style="display:flex; align-items:center;"></div>
                <h3 id="editor-filename">editor.txt</h3>
            </div>
            <button class="icon-btn modal-close">&times;</button>
        </div>
        <div class="modal-body" style="padding:0; display:flex;">
            <div id="editor-gutter" style="background:var(--night-900); padding:14px 8px; border-right:1px solid var(--glass-border); font-family:var(--font-mono); font-size:13px; color:var(--text-dim); text-align:right; min-width:40px; user-select:none; overflow:hidden;"></div>
            <textarea id="file-editor-text" class="textarea-hud" style="flex:1; border:none; border-radius:0;"></textarea>
        </div>
        <div class="modal-footer">
            <button class="icon-btn modal-close" style="font-size:13px; font-weight:600;">DISCARD</button>
            <button id="editor-save-btn" class="btn-primary" style="padding:8px 20px; font-size:13px;">SAVE CHANGES</button>
        </div>
    </div>
</div>
