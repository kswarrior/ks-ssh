<div class="tab-panel hidden" id="tab-files">
  <div class="files-panel">
    <div class="files-toolbar">
      <div class="toolbar-actions">
        <button class="btn-primary" id="upload-btn">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Upload
        </button>
        <button class="hdr-icon-btn" id="new-folder-btn" title="New Folder">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 2h9a2 2 0 0 1 2 2v12z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
        </button>
        <button class="hdr-icon-btn" id="files-refresh-btn" title="Refresh">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        </button>
      </div>
      <div class="path-bar-container">
        <div class="path-bar">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span id="current-path">/</span>
        </div>
      </div>
    </div>
    <div class="breadcrumb" id="breadcrumb"></div>
    <div class="files-list" id="files-list"></div>

    <div class="bulk-bar hidden" id="bulk-bar">
      <span id="bulk-count">0 selected</span>
      <div class="bulk-actions">
        <button class="btn-danger-sm" id="bulk-delete">Delete</button>
        <button class="btn-secondary-sm" id="bulk-cancel">Cancel</button>
      </div>
    </div>
  </div>
</div>

<input type="file" id="file-input" multiple class="hidden" />
