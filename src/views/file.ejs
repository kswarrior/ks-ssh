<div class="tab-panel hidden" id="tab-files">
  <div class="hud-container">
    <div class="hud-view-header">
        <div class="hud-title-wrap">
            <h1>Storage HUD</h1>
            <div id="breadcrumb" class="breadcrumb">/root</div>
        </div>
        <div class="hud-action-group">
            <div class="search-wrap">
                <input type="text" id="files-search" placeholder="SEARCH..." class="input-hud-compact" />
                <button id="deep-search-btn" class="icon-btn-search" title="Deep Search (Recursive)"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg></button>
            </div>

            <div class="dropdown-wrapper">
                <button class="btn-primary" id="add-multi-btn"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" style="margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> ADD</button>
                <div class="dropdown-menu dropdown-menu-sm hidden" id="add-dropdown">
                    <div class="menu-item" id="new-file-btn-v2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg> NEW FILE</div>
                    <div class="menu-item" id="new-folder-btn-v2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 2h9a2 2 0 0 1 2 2v12z"/></svg> NEW FOLDER</div>
                </div>
            </div>

            <div class="dropdown-wrapper">
                <button class="btn-primary btn-secondary" id="upload-multi-btn"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" style="margin-right:4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> UPLOAD</button>
                <div class="dropdown-menu dropdown-menu-sm hidden" id="upload-dropdown">
                    <div class="menu-item" id="upload-storage-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg> LOCAL STORAGE</div>
                    <div class="menu-item" id="upload-url-btn-v2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> REMOTE URL</div>
                </div>
            </div>

            <button id="select-btn" class="icon-btn" title="Toggle Multi-Select"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="9 11 12 14 22 4"/></svg></button>
            <button id="files-refresh-btn" class="icon-btn" title="Refresh"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></button>
            <button onclick="window.openDefaultPathModal()" class="icon-btn" title="Set Default Path"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></button>
        </div>
    </div>

    <div id="filter-bar" class="filter-bar">
        <span class="filter-label">FILTERS:</span>
        <div class="filter-chips">
            <div class="filter-chip active" data-ext="all">ALL</div>
            <div class="filter-chip" data-ext="js">JS</div>
            <div class="filter-chip" data-ext="json">JSON</div>
            <div class="filter-chip" data-ext="py">PY</div>
            <div class="filter-chip" data-ext="html">HTML</div>
            <div class="filter-chip" data-ext="css">CSS</div>
            <div class="filter-chip" data-ext="sh">SH</div>
            <div class="filter-chip" data-ext="img">IMG</div>
            <div class="filter-chip" data-ext="zip">ZIP</div>
            <div class="filter-chip" id="hidden-toggle-btn">HIDDEN</div>
        </div>
    </div>

    <div class="hud-content-split flex-1">
        <aside class="files-sidebar">
            <div class="sidebar-label">QUICK LINKS</div>
            <div class="sidebar-links">
                <div class="sidebar-link" data-path="/root">ROOT</div>
                <div class="sidebar-link" data-path="/home">HOME</div>
                <div class="sidebar-link" data-path="/etc">ETC</div>
                <div class="sidebar-link" data-path="/tmp">TMP</div>
                <div class="sidebar-link" data-path="/var/www">WEB</div>
            </div>

            <div class="sidebar-label" style="margin-top:20px; display:flex; justify-content:space-between; align-items:center;">
                <span>BOOKMARKS</span>
                <button id="add-bookmark-btn" class="icon-btn" style="padding:2px;" title="Bookmark Current Folder"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/><line x1="12" y1="7" x2="12" y2="13"/><line x1="9" y1="10" x2="15" y2="10"/></svg></button>
            </div>
            <div class="sidebar-links" id="bookmarks-list">
                <!-- Bookmarks injected here -->
            </div>
        </aside>
        <div id="files-list" class="files-list-vertical flex-1"></div>
    </div>

    <!-- Create Panel (Subpage) -->
    <div id="files-create-panel" class="hidden flex-1" style="padding:20px;">
        <div class="label-box"><label class="breadcrumb-flat">CREATE NEW RESOURCE</label></div>
        <div class="flex-center-gap-12" style="margin-bottom:20px;">
            <button class="btn-primary create-type-btn active" data-type="file">FILE</button>
            <button class="btn-primary btn-secondary create-type-btn" data-type="folder">FOLDER</button>
        </div>

        <div class="label-box"><label class="breadcrumb-flat">NAME / IDENTIFIER</label></div>
        <input type="text" id="create-name-input" class="input-hud" placeholder="e.g. config.json" style="margin-bottom:24px;" />

        <div class="flex-center-gap-12">
            <button id="create-cancel-btn" class="btn-primary btn-secondary">CANCEL</button>
            <button id="create-confirm-btn" class="btn-primary">CONFIRM CREATE</button>
        </div>
    </div>

    <div id="bulk-bar" class="hidden bulk-bar">
        <div id="bulk-count" class="bulk-count">0 ITEMS</div>
        <div class="hud-action-group">
            <button id="bulk-zip" class="btn-primary btn-secondary">ZIP</button>
            <button id="bulk-delete" class="btn-primary btn-danger">DELETE</button>
            <button id="bulk-cancel" class="icon-btn"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
    </div>
  </div>
</div>

<input type="file" id="file-input" multiple class="hidden" />

<!-- Context Menu -->
<div id="file-context-menu" class="context-menu hidden">
    <div class="menu-item" id="ctx-download"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Download</div>
    <div class="menu-item" id="ctx-edit"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</div>
    <div class="menu-item" id="ctx-rename"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg> Rename</div>
    <div class="menu-item" id="ctx-copy"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy</div>
    <div class="menu-item" id="ctx-move"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg> Move</div>
    <div class="menu-divider"></div>
    <div class="menu-item danger" id="ctx-delete"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</div>
</div>

<!-- URL Upload Modal -->
<div class="modal-overlay hidden" id="url-upload-modal">
    <div class="modal">
        <div class="modal-header"><h3>Upload from URL</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body">
            <div class="label-box"><label class="breadcrumb-flat">RESOURCE URL</label></div>
            <input type="text" id="upload-url-input" class="input-hud" placeholder="https://example.com/file.zip" />
        </div>
        <div class="modal-footer">
            <button class="icon-btn modal-close btn-text-hud">CANCEL</button>
            <button id="url-upload-confirm" class="btn-primary">UPLOAD</button>
        </div>
    </div>
</div>

<!-- Image Preview Modal -->
<div class="modal-overlay hidden" id="image-preview-modal">
    <div class="modal modal-lg">
        <div class="modal-header"><h3 id="preview-filename">image.png</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body flex-center" style="background:#111; min-height:300px;">
            <img id="preview-img" style="max-width:100%; max-height:70vh; object-fit:contain;" />
        </div>
        <div class="modal-footer">
            <button class="btn-primary modal-close">CLOSE PREVIEW</button>
        </div>
    </div>
</div>

<!-- Editor Modal -->
<div class="modal-overlay hidden" id="file-editor-modal">
    <div class="modal modal-lg">
        <div class="modal-header"><h3 id="editor-filename">editor.txt</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body modal-body-flush">
            <div class="editor-container">
                <pre id="editor-highlight" class="editor-highlight"></pre>
                <textarea id="file-editor-text" class="textarea-hud" spellcheck="false"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="icon-btn modal-close btn-text-hud">DISCARD</button>
            <button id="editor-save-btn" class="btn-primary">SAVE CHANGES</button>
        </div>
    </div>
</div>
