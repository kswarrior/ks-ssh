<div class="modal-overlay hidden" id="term-close-modal">
  <div class="modal">
    <div class="modal-header"><h3>Close Terminal</h3><button class="modal-close" id="term-close-modal-x">&times;</button></div>
    <div class="modal-body">
      <p>Type <strong>KS SSH</strong> to confirm.</p>
      <input type="text" id="term-close-input" />
    </div>
    <div class="modal-footer">
      <button class="btn-secondary" id="term-close-cancel">Cancel</button>
      <button class="btn-danger" id="term-close-confirm" disabled>Close</button>
    </div>
  </div>
</div>
