<div class="modal-overlay hidden" id="settings-modal">
    <div class="modal">
        <div class="modal-header"><h3>HUD Customization</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body">
            <div class="label-box"><label class="breadcrumb-flat">THEME ACCENT COLOR</label></div>
            <div class="flex-center-gap-12 space-t-8" style="margin-bottom:20px;">
                <div class="color-swatch active" data-color="#00a2ff" style="background:#00a2ff; width:30px; height:30px; border-radius:50%; cursor:pointer; border:2px solid #fff;"></div>
                <div class="color-swatch" data-color="#ff0055" style="background:#ff0055; width:30px; height:30px; border-radius:50%; cursor:pointer;"></div>
                <div class="color-swatch" data-color="#00ff99" style="background:#00ff99; width:30px; height:30px; border-radius:50%; cursor:pointer;"></div>
                <div class="color-swatch" data-color="#ff9900" style="background:#ff9900; width:30px; height:30px; border-radius:50%; cursor:pointer;"></div>
                <div class="color-swatch" data-color="#9900ff" style="background:#9900ff; width:30px; height:30px; border-radius:50%; cursor:pointer;"></div>
            </div>

            <div class="label-box"><label class="breadcrumb-flat">TERMINAL FONT SIZE</label></div>
            <div class="flex-center-gap-12 space-t-8" style="margin-bottom:20px;">
                <input type="range" id="settings-font-size" min="10" max="24" step="1" value="13" style="flex:1;" />
                <span id="font-size-val" class="mono-dim-14">13px</span>
            </div>

            <div class="label-box"><label class="breadcrumb-flat">BACKGROUND GLASS OPACITY</label></div>
            <div class="flex-center-gap-12 space-t-8" style="margin-bottom:20px;">
                <input type="range" id="settings-opacity" min="0.5" max="1" step="0.05" value="0.85" style="flex:1;" />
                <span id="opacity-val" class="mono-dim-14">0.85</span>
            </div>

            <div class="label-box"><label class="breadcrumb-flat">TERMINAL COLORS</label></div>
            <div class="flex-center-gap-12 space-t-8" style="flex-wrap: wrap; gap: 16px;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="color" id="settings-term-text" value="#00a2ff" class="input-hud" style="width:40px; height:30px; padding:2px; border:none;" />
                    <span class="mono-dim-14">TEXT</span>
                </div>
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="color" id="settings-term-bg" value="#000000" class="input-hud" style="width:40px; height:30px; padding:2px; border:none;" />
                    <span class="mono-dim-14">BG</span>
                </div>
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="color" id="settings-term-cursor" value="#00a2ff" class="input-hud" style="width:40px; height:30px; padding:2px; border:none;" />
                    <span class="mono-dim-14">CURSOR</span>
                </div>
            </div>

            <div class="label-box" style="margin-top:20px;"><label class="breadcrumb-flat">CURSOR STYLE</label></div>
            <div class="flex-center-gap-12 space-t-8">
                <select id="settings-cursor-style" class="input-hud" style="flex:1;">
                    <option value="block">BLOCK</option>
                    <option value="underline">UNDERLINE</option>
                    <option value="bar">BAR</option>
                </select>
            </div>

            <div class="flex-center-gap-12 space-t-8" style="margin-top:20px;">
                <label class="breadcrumb-flat" style="flex:1; cursor:pointer; display:flex; align-items:center; gap:8px;">
                    <input type="checkbox" id="settings-cursor-blink" checked style="width:16px; height:16px;" />
                    CURSOR BLINKING
                </label>
            </div>

            <div class="label-box" style="margin-top:20px; border-top: 1px solid var(--glass-border); padding-top:20px;"><label class="breadcrumb-flat">FILES HUD</label></div>
            <div class="flex-center-gap-12 space-t-8" style="margin-bottom:12px;">
                <input type="range" id="settings-files-size" min="10" max="20" step="1" value="13" style="flex:1;" />
                <span id="files-size-val" class="mono-dim-14">13px</span>
            </div>
            <div class="flex-center-gap-12">
                <input type="color" id="settings-files-color" value="#ffffff" class="input-hud" style="width:40px; height:30px; padding:2px; border:none;" />
                <span class="mono-dim-14">TEXT COLOR</span>
            </div>

            <div class="label-box" style="margin-top:20px; border-top: 1px solid var(--glass-border); padding-top:20px;"><label class="breadcrumb-flat">PORTS HUD</label></div>
            <div class="flex-center-gap-12 space-t-8" style="margin-bottom:12px;">
                <input type="range" id="settings-ports-size" min="10" max="20" step="1" value="13" style="flex:1;" />
                <span id="ports-size-val" class="mono-dim-14">13px</span>
            </div>
            <div class="flex-center-gap-12">
                <input type="color" id="settings-ports-color" value="#ffffff" class="input-hud" style="width:40px; height:30px; padding:2px; border:none;" />
                <span class="mono-dim-14">TEXT COLOR</span>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-primary modal-close">DONE</button>
        </div>
    </div>
</div>

<div class="modal-overlay hidden" id="tcp-terminal-panel">
    <div class="modal modal-lg" style="height: 80vh; display: flex; flex-direction: column;">
        <div class="modal-header">
            <div class="flex-center-gap-12">
                <h3 class="mono-dim-14">TCP INTERACTION</h3>
                <span id="tcp-port-badge" class="breadcrumb-no-margin">:0000</span>
            </div>
            <button class="icon-btn" id="tcp-terminal-close">&times;</button>
        </div>
        <div class="modal-body flex-1" style="background:#000; padding:10px; display:flex; flex-direction:column; gap:10px;">
            <div id="tcp-output" style="flex:1; border:1px solid var(--glass-border); border-radius:4px; padding:10px; font-family:var(--font-mono); font-size:12px; color:var(--text-main); overflow-y:auto; white-space:pre-wrap;"></div>
            <div style="display:flex; gap:8px;">
                <input type="text" id="tcp-input" class="input-hud" style="flex:1;" placeholder="Send data..." />
                <button id="tcp-send-btn" class="btn-primary" style="min-width: 80px;">SEND</button>
            </div>
        </div>
        <div class="modal-footer">
            <button id="tcp-clear-btn" class="icon-btn btn-text-hud">CLEAR</button>
            <button id="tcp-disconnect-btn" class="btn-primary btn-danger">DISCONNECT</button>
        </div>
    </div>
</div>

<div class="modal-overlay hidden" id="default-path-modal">
    <div class="modal">
        <div class="modal-header"><h3>Set Default Location</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body">
            <div class="label-box"><label class="breadcrumb-flat">MANUAL PATH ENTRY</label></div>
            <input type="text" id="def-path-manual" class="input-hud" placeholder="/root/run/work" />

            <div class="label-box" style="margin-top:20px;"><label class="breadcrumb-flat">MINI-CLI EXPLORER</label></div>
            <div class="mini-cli-container">
                <div id="mini-cli-output" class="mini-cli-output">Current: /root</div>
                <div class="mini-cli-input-wrap">
                    <span class="mini-cli-prompt">></span>
                    <input type="text" id="mini-cli-input" class="mini-cli-input" placeholder="cd .., ls, mkdir..." />
                </div>
            </div>
            <p class="mono-dim-11" style="margin-top:8px;">Commands: cd [path], ls, mkdir [name]</p>
        </div>
        <div class="modal-footer">
            <button class="icon-btn modal-close btn-text-hud">CANCEL</button>
            <button id="def-path-confirm" class="btn-primary">SAVE AS DEFAULT</button>
        </div>
    </div>
</div>

<div class="modal-overlay hidden" id="term-close-modal">
    <div class="modal modal-sm">
        <div class="modal-header"><h3>Close Terminal</h3><button class="icon-btn modal-close">&times;</button></div>
        <div class="modal-body">
            <p class="modal-p-main">Are you sure you want to kill this terminal session?</p>
            <p class="modal-p-sub">Type <span class="text-blue">KS SSH</span> to confirm:</p>
            <input type="text" id="term-close-input" class="input-hud" placeholder="KS SSH" />
        </div>
        <div class="modal-footer">
            <button class="icon-btn modal-close btn-text-hud" id="term-close-cancel">CANCEL</button>
            <button id="term-close-confirm" class="btn-primary btn-danger" disabled>CLOSE SESSION</button>
        </div>
    </div>
</div>

<div class="modal-overlay hidden" id="port-preview-panel">
    <div class="modal modal-port-preview">
        <div class="modal-header">
            <div class="flex-center-gap-12">
                <h3 id="port-preview-url" class="mono-dim-14">localhost:0000</h3>
                <span id="port-preview-badge" class="breadcrumb-no-margin">:0000</span>
                <label style="display:flex; align-items:center; gap:4px; font-size:10px; color:var(--text-dim); cursor:pointer;">
                    <input type="checkbox" id="port-ssl-toggle" style="width:12px; height:12px;" /> SSL
                </label>
            </div>
            <button class="icon-btn" id="port-preview-close"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
        <div class="modal-body flex-1 modal-body-flush bg-white">
            <iframe id="port-preview-iframe" class="full-iframe" src="about:blank"></iframe>
        </div>
        <div class="modal-footer">
            <button class="btn-primary" id="port-preview-refresh">REFRESH PAGE</button>
        </div>
    </div>
</div>
