<div class="modal-overlay hidden" id="term-close-modal">
  <div class="modal">
    <div class="modal-header"><h3>Close Terminal</h3><button class="modal-close" id="term-close-modal-x">&times;</button></div>
    <div class="modal-body">
      <p>Type <strong>KS SSH</strong> to confirm.</p>
      <input type="text" id="term-close-input" />
    </div>
    <div class="modal-footer">
      <button class="btn-secondary" id="term-close-cancel">Cancel</button>
      <button class="btn-danger" id="term-close-confirm" disabled>Close</button>
    </div>
  </div>
</div>

<!-- Port Preview Panel -->
<div class="modal-overlay hidden" id="port-preview-panel">
    <div class="modal" style="max-width: 90vw; width: 1000px; height: 85vh; display: flex; flex-direction: column;">
        <div class="modal-header">
            <div style="display:flex; align-items:center; gap:12px;">
                <h3 id="port-preview-url" style="font-family:var(--font-mono); font-size:14px; color:var(--text-dim);">localhost:0000</h3>
                <span id="port-preview-badge" class="breadcrumb" style="margin-top:0;">:0000</span>
            </div>
            <button class="icon-btn" id="port-preview-close">&times;</button>
        </div>
        <div class="modal-body" style="flex:1; padding:0; background: white;">
            <iframe id="port-preview-iframe" style="width:100%; height:100%; border:none;" src="about:blank"></iframe>
        </div>
        <div class="modal-footer">
            <button class="btn-primary" id="port-preview-refresh" style="padding:8px 16px; font-size:12px;">REFRESH PAGE</button>
        </div>
    </div>
</div>
