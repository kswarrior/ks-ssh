<div class="tab-panel" id="tab-terminals">
  <div class="terminal-hud-wrapper">

    <!-- TOP SECTION: Tabs, Actions, and Keypad -->
    <div id="terminal-header-area" class="hidden">
        <!-- Tabs & Basic Actions -->
        <div id="terminal-tabs-container">
          <div class="flex-1 flex-center-gap-4-hidden">
            <div id="terminal-tabs-list"></div>
            <button id="add-term-btn" class="terminal-add-btn">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
          </div>

          <div class="hud-action-group">
              <button id="t-font-dec" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
              <button id="t-font-inc" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
              <button id="t-clear-btn" class="icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
              <button id="t-custom-btn" class="btn-primary" style="padding: 2px 8px; font-size: 9px; height: 24px;">CUSTOM ACTION</button>
          </div>
        </div>

        <!-- Keypad (Ultra Compact) -->
        <div id="terminal-keypad" class="terminal-keypad hidden">
            <div class="keypad-row">
                <button class="t-key" data-key="esc">ESC</button>
                <button class="t-key" data-key="tab">TAB</button>
                <button class="t-key" data-key="backspace">BKSP</button>
                <div class="key-separator"></div>
                <button class="t-key key-toggle" data-key="ctrl">CTRL</button>
                <button class="t-key key-toggle" data-key="alt">ALT</button>
                <div class="key-separator"></div>
                <button class="t-key" data-key="arrowup">↑</button>
                <button class="t-key" data-key="arrowdown">↓</button>
                <button class="t-key" data-key="arrowleft">←</button>
                <button class="t-key" data-key="arrowright">→</button>
            </div>
        </div>
    </div>

    <!-- MAIN TERMINAL AREA -->
    <div class="terminal-hud-content" id="terminals-area"></div>

    <!-- EMPTY STATE -->
    <div id="terminals-empty" class="empty-state">
      <div class="empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
      </div>
      <h2 class="empty-title">No Terminals Open</h2>
      <p class="empty-subtitle">Start a session to interact with your system.</p>
      <button id="empty-new-term" class="btn-primary">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          New Terminal
      </button>
    </div>

  </div>
</div>
