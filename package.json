{
  "name": "ks-ssh",
  "version": "1.0.0",
  "description": "KS SSH - Powerful browser-based SSH with terminals, ports, and file management",
  "main": "src/server.js",
  "bin": {
    "ks-ssh": "./src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "build-pkg": "npx pkg . --targets node18-linux-x64 --output ks-ssh"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.0.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [
      "src/public/**/*",
      "node_modules/node-pty/build/Release/**/*.node",
      "node_modules/node-pty/lib/**/*"
    ],
    "targets": [
      "node18-linux-x64"
    ],
    "outputPath": "."
  }
}
